{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SISO Internal Lab Task",
  "description": "Task schema for SISO Internal Lab",
  "type": "object",
  "required": ["id", "title", "status", "priority", "target_agent", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique task ID, format: TASK-XXXX",
      "pattern": "^TASK-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "description": "Short, descriptive title"
    },
    "status": {
      "type": "string",
      "enum": ["backlog", "queued", "in_progress", "blocked", "completed", "cancelled"],
      "description": "Current lifecycle stage"
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "Execution priority"
    },
    "target_agent": {
      "type": "string",
      "description": "Which agent should handle this task"
    },
    "category": {
      "type": "string",
      "enum": ["feature", "bugfix", "infrastructure", "research", "content", "setup"],
      "description": "Task type"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "description": "Who created this: 'human' or agent name"
    },
    "spec": {
      "type": "object",
      "description": "The full task specification",
      "properties": {
        "description": { "type": "string" },
        "objectives": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string" }
        },
        "context": { "type": "string" },
        "files_affected": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of tasks that must complete first"
    },
    "execution_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "action": { "type": "string" },
          "by": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
